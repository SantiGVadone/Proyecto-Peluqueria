# Dependencias (Nunca se suben, pesan mucho)
node_modules/

# Compilación (TypeScript genera archivos .js en esta carpeta)
dist/
build/
out/

# Variables de Entorno (¡CRÍTICO! Acá están tus claves de DB y JWT)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs (Errores generados por el sistema)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Configuraciones de Editores (VS Code, IntelliJ, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Archivos del Sistema Operativo
.DS_Store
Thumbs.db

# Base de datos local (Por si usas algún archivo de persistencia local)
*.sqlite