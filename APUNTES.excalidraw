      "updated": 1771879395971,
      "link": null,
      "locked": false,
      "text": "Relaciones:\n    Negocio <-> JEFE, EMPLEADOS, CLIENTES\n    EMPLEADOS <-> TURNOS\n    CLIENTES <-> TURNOS\n    TURNOS <-> SERVICIOS",
      "fontSize": 20,
